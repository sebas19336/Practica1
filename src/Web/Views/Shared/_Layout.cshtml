<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Web</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 text-gray-800 flex flex-col min-h-screen">

    <header class="bg-white shadow mb-6">
        <div class="container mx-auto px-4 py-3 flex items-center justify-between">
            <a asp-area="" asp-controller="Home" asp-action="Index"
               class="text-xl font-bold text-blue-600 hover:text-blue-800">
                🏠 Web
            </a>
            <nav class="flex gap-6">
                <a asp-area="" asp-controller="Home" asp-action="Index"
                   class="text-gray-600 hover:text-blue-600 font-medium transition">Home</a>
                <a asp-area="" asp-controller="Home" asp-action="Privacy"
                   class="text-gray-600 hover:text-blue-600 font-medium transition">Privacy</a>
                <a asp-area="" asp-controller="Product" asp-action="Index"
                   class="text-gray-600 hover:text-blue-600 font-medium transition">Productos</a>
            </nav>
        </div>
    </header>

    <main class="container mx-auto px-4 flex-grow pb-6">
        @RenderBody()
    </main>

    <footer class="bg-white border-t text-gray-400 text-sm py-4 mt-6">
        <div class="container mx-auto px-4">
            &copy; 2026 - Web -
            <a asp-area="" asp-controller="Home" asp-action="Privacy"
               class="hover:text-blue-500 underline">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>