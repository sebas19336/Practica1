@model Practica1.Domain.Entities.Product

<div class="max-w-lg mx-auto">
    <div class="bg-white rounded-2xl shadow overflow-hidden">
        <div class="bg-yellow-400 text-gray-900 px-6 py-4">
            <h4 class="text-xl font-semibold">✏️ Editar Producto</h4>
        </div>
        <div class="p-6">
            <form asp-action="Edit" method="post" class="space-y-4">
                <input type="hidden" asp-for="Id" />
                
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All"
                         class="bg-red-50 border border-red-300 text-red-700 rounded-lg px-4 py-3 text-sm"></div>
                }


                <div>
                    <label asp-for="Name" class="block text-sm font-semibold text-gray-700 mb-1">Nombre</label>
                    <input asp-for="Name" placeholder="Nombre del producto"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-yellow-400" />
                    <span asp-validation-for="Name" class="text-red-500 text-xs"></span>
                </div>

                <div>
                    <label asp-for="Price" class="block text-sm font-semibold text-gray-700 mb-1">Precio</label>
                    <div class="flex">
                        <span
                        class="bg-gray-100 border border-r-0 border-gray-300 rounded-l-lg px-3 py-2 text-sm text-gray-500">$</span>
                        <input asp-for="Price" placeholder="0.00"
                               class="w-full border border-gray-300 rounded-r-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-yellow-400" />
                    </div>
                    <span asp-validation-for="Price" class="text-red-500 text-xs"></span>
                </div>

                <div>
                    <label asp-for="CategoryId" class="block text-sm font-semibold text-gray-700 mb-1">Categoría</label>
                    <select asp-for="CategoryId"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-yellow-400">
                        <option value="">-- Selecciona una categoría --</option>
                        @foreach (var c in ViewBag.Categories)
                        {
                            <option value="@c.Id">@c.Id - @c.Name</option>
                        }
                    </select>
                </div>

                <div class="flex gap-2 pt-2">
                    <button type="submit"
                            class="w-full bg-yellow-400 hover:bg-yellow-500 text-gray-900 font-semibold py-2 rounded-lg transition">
                        💾 Actualizar
                    </button>
                    <a asp-action="Index"
                           class="w-full text-center border border-gray-300 hover:bg-gray-100 text-gray-600 font-semibold py-2 rounded-lg transition">
                        Cancelar
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>